<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Grouped Posts by Category</title>
    <style>
      body { font-family: Arial, sans-serif; margin: 2rem; max-width: 900px; }
      h1 { margin-bottom: 0.5rem; }
      .category { margin-bottom: 1.5rem; padding: 1rem; border: 1px solid #ddd; border-radius: 8px; }
      .category h2 { margin: 0 0 0.5rem; }
      ul { margin: 0; padding-left: 1.2rem; }
      a { color: #0066cc; }
    </style>
  </head>
  <body>
    <h1>Grouped Posts by Category</h1>
    <p><a href="/">Back to home</a></p>
    <% if (categories) { %>
      <% categories.forEach(category => { %>
        <section class="category">
          <h2><%= category.name || 'Unnamed category' %></h2>
          <ul>
            <% if (category.posts && category.posts.length) { %>
              <% category.posts.forEach(post => { %>
                <li><%= post.title || 'Untitled post' %></li>
              <% }); %>
            <% } else { %>
              <li>No posts for this category.</li>
            <% } %>
          </ul>
        </section>
      <% }); %>
    <% } else { %>
      <p>No categories available.</p>
    <% } %>
  </body>
</html>